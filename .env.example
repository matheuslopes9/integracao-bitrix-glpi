# ===== Servidor =====
PORT=3000
LOG_LEVEL=info
NODE_ENV=production

# ===== Banco (SQLite local) =====
DATABASE_PATH=./data/integrador.db

# ===== GLPI =====
# URL base da sua instância GLPI (sem /apirest.php no final)
GLPI_BASE_URL=https://glpi.seudominio.com.br
# App-Token criado em Configurar > Geral > API
GLPI_APP_TOKEN=cole_aqui_o_app_token
# User Token de um usuário com perfil que possa criar/atualizar tickets, ITILFollowup e Ticket_User
GLPI_USER_TOKEN=cole_aqui_o_user_token
# Segredo HMAC configurado no webhook do GLPI (para validar X-GLPI-Signature)
GLPI_WEBHOOK_SECRET=troque_por_um_segredo_longo_aleatorio
# Entidade padrão para ações originadas no Bitrix (id numérico da entidade GLPI)
GLPI_DEFAULT_ENTITY_ID=0

# ===== Bitrix24 =====
# URL do webhook entrante (Aplicativos > Webhooks > Webhook entrante). Termine com /
# Exemplo: https://suaempresa.bitrix24.com.br/rest/1/abcdef123456/
BITRIX_WEBHOOK_URL=https://suaempresa.bitrix24.com.br/rest/1/abcdef123456/
# Segredo HMAC para validar webhooks de saída do Bitrix (se você usar os events outbound)
BITRIX_WEBHOOK_SECRET=troque_por_um_segredo_longo_aleatorio
# ID do usuário Bitrix usado como CREATED_BY quando o chamado veio do GLPI
BITRIX_DEFAULT_CREATOR_ID=1
# ID do usuário Bitrix usado como RESPONSIBLE_ID quando o GLPI ainda não atribuiu um técnico
BITRIX_DEFAULT_RESPONSIBLE_ID=1
# (Opcional) ID do grupo/projeto Bitrix onde as tarefas serão criadas
BITRIX_DEFAULT_GROUP_ID=

# ===== Cruzamento por CNPJ =====
# Código UF_CRM_... do campo customizado da Company que guarda o CNPJ.
# Para descobrir o seu: npx tsx scripts/find-cnpj-field.ts
# (vai listar todos os UF_CRM_* da sua Company e o valor de cada)
BITRIX_CNPJ_FIELD=UF_CRM_1588120619499

# ===== Modo simulação (opcional) =====
# DRY_RUN=true faz o integrador receber webhooks e simular tudo (sem criar/alterar
# nada no Bitrix nem no GLPI). Útil para testar em produção sem efeitos.
DRY_RUN=false
